function my-update () {
  sudo env DEBIAN_FRONTEND=noninteractive NEEDRESTART_MODE=a sh -c '
    apt-get update -y &&
    apt-get upgrade -y -o Dpkg::Options::=--force-confold &&
    apt-get autoremove -y &&
    apt-get autoremove --purge -y &&
    apt-get autoclean &&
    apt-get clean &&
    snap refresh
  ' &&
  brew update &&
  brew upgrade -y &&
  brew cleanup
}

# --- AI tooling updater -------------------------------------------------------
# my-update-ai: update the AI dev stack in one shot - Claude Code (CLI +
# marketplaces/plugins/bundled skills) and Pilot, which itself cascades updates to
# RTK, CodeGraph, the LSP/Chrome-DevTools plugins, and the Codex integration.
# Each tool is isolated: a missing CLI is skipped, a failing step is recorded but
# does NOT abort the rest. Prints a summary and exits non-zero on failure.
# OS/apt/brew live in `my-update` (which also covers the codex + rtk brew casks);
# run `my-update && my-update-ai` for the full sweep.
# Note: restart claude & pilot afterwards for updates/plugins to take effect.

# _ai_step <label> <bin> <cmd...> - skip when <bin> is absent, else run <cmd> and record.
function _ai_step () {
  local label="$1" bin="$2"; shift 2
  if ! command -v "$bin" >/dev/null 2>&1; then
    printf '\n\033[2m-- skip  %s (%s not installed)\033[0m\n' "$label" "$bin"
    _ai_skip+=("$label"); return 0
  fi
  printf '\n\033[1m==> %s\033[0m\n' "$label"
  # Cap each step so a wedged tool can never freeze the whole run. A shell
  # function can't be wrapped by `timeout` (it self-guards internally); binaries
  # get a generous ceiling (default 600s, override with CB_AI_STEP_TIMEOUT).
  local limit="${CB_AI_STEP_TIMEOUT:-600}" rc
  if [ "$(type -t "$1")" = "function" ]; then
    "$@"; rc=$?
  else
    timeout -k 10 "$limit" "$@"; rc=$?
    [ "$rc" -eq 124 ] && printf '\033[31mFAIL %s (timed out after %ss; continuing)\033[0m\n' "$label" "$limit"
  fi
  if [ "$rc" -eq 0 ]; then
    _ai_ok+=("$label")
  else
    [ "$rc" -eq 124 ] || printf '\033[31mFAIL %s (continuing)\033[0m\n' "$label"
    _ai_fail+=("$label")
  fi
}

# Claude Code: refresh every marketplace, then each installed plugin (which also
# pulls the skills/agents those plugins bundle). No native --all, so loop the list.
# A dead/stale entry (plugin removed upstream) is reported but does NOT fail the
# step - only a marketplace-refresh failure does.
function _ai_update_claude_plugins () {
  timeout -k 5 120 claude plugin marketplace update </dev/null || return 1
  # Read the plugin list on FD 3 and give each update its own /dev/null stdin, so
  # a plugin command can't consume the loop's input pipe and hang it (a `while
  # read` loop must never share stdin with commands it runs). Each update is also
  # time-capped so one wedged plugin is skipped, not fatal.
  local p failed=()
  while IFS= read -r p <&3; do
    [ -n "$p" ] || continue
    timeout -k 5 90 claude plugin update "$p" </dev/null || failed+=("$p")
  done 3< <(claude plugin list 2>/dev/null | grep -oE '[A-Za-z0-9._-]+@[A-Za-z0-9._-]+' | sort -u)
  [ ${#failed[@]} -eq 0 ] || printf '\033[2m   note: %d plugin(s) did not update: %s\033[0m\n' "${#failed[@]}" "${failed[*]}"
  return 0
}

function my-update-ai () {
  local _ai_ok=() _ai_fail=() _ai_skip=()

  # CLI first (the plugin refresh below runs *through* it), then Pilot's meta-update,
  # then the marketplace plugins Pilot does not manage (voltagent, ruby-skills, ...).
  _ai_step "Claude Code CLI"        claude claude update
  _ai_step "Pilot"                  pilot  pilot update --yes
  _ai_step "Claude plugins/skills"  claude _ai_update_claude_plugins

  printf '\n\033[1m=== my-update-ai summary ===\033[0m\n'
  printf '\033[32mupdated:\033[0m %s\n' "${_ai_ok[*]:-none}"
  [ ${#_ai_skip[@]} -gt 0 ] && printf '\033[2mskipped:\033[0m %s\n' "${_ai_skip[*]}"
  [ ${#_ai_fail[@]} -gt 0 ] && printf '\033[31mfailed :\033[0m %s\n' "${_ai_fail[*]}"
  printf '\033[2mReminder: restart claude & pilot for updates to take effect.\033[0m\n'
  return ${#_ai_fail[@]}
}
