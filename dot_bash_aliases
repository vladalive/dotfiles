function gh-pr-create-statusgator () {
  URL=$1
  ISSUE_NUMBER=$(printf '%s\n' "$URL" | grep -o '[0-9]\+' | tail -1)
  SHORT_URL=$(printf '%s\n' "$URL" | sed -n 's#^\(https://trello\.com/c/[^/[:space:]]*\).*$#\1#p')
  if [ -z "$ISSUE_NUMBER" ] || [ -z "$SHORT_URL" ]; then
    echo "gh-pr-create-statusgator: expected a Trello card URL" >&2
    return 1
  fi

  gh pr create --base master --reviewer cbartlett,alibby --fill --body "* [#$ISSUE_NUMBER]($SHORT_URL)"
}

