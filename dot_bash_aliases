gpg-cache() {
  if ! command -v gpg >/dev/null 2>&1; then
    echo "gpg-cache: gpg is not installed" >&2
    return 1
  fi

  if ! command -v git >/dev/null 2>&1; then
    echo "gpg-cache: git is not installed" >&2
    return 1
  fi

  if GPG_TTY_VALUE=$(tty 2>/dev/null); then
    export GPG_TTY="$GPG_TTY_VALUE"
  fi

  SIGNING_KEY=$(git config --get user.signingkey)
  if [ -z "$SIGNING_KEY" ]; then
    echo "gpg-cache: git user.signingkey is not configured" >&2
    return 1
  fi

  mkdir -p "$HOME/tmp" || return 1
  if [ ! -f "$HOME/tmp/gpg.txt" ]; then
    printf 'gpg cache warmup\n' > "$HOME/tmp/gpg.txt" || return 1
  fi

  gpg --yes --armor --detach-sign --local-user "$SIGNING_KEY" "$HOME/tmp/gpg.txt"
}

gpg-reset() {
  if ! command -v gpgconf >/dev/null 2>&1; then
    echo "gpg-reset: gpgconf is not installed" >&2
    return 1
  fi

  if ! command -v gpg-connect-agent >/dev/null 2>&1; then
    echo "gpg-reset: gpg-connect-agent is not installed" >&2
    return 1
  fi

  if GPG_TTY_VALUE=$(tty 2>/dev/null); then
    export GPG_TTY="$GPG_TTY_VALUE"
  fi

  gpgconf --kill gpg-agent || return 1
  gpgconf --launch gpg-agent || return 1
  gpg-connect-agent updatestartuptty /bye >/dev/null
}

gpg-resolve() {
  gpg-reset; gpg-cache
}

