function git-rebase-all () {
  BASE=${1:-master}
  git checkout $BASE
  for branch in $(git for-each-ref --format='%(refname:short)' refs/heads --no-merged | grep -v -E "^($BASE)$"); do
    WORKTREE=$(git worktree list --porcelain | awk -v branch="refs/heads/$branch" 'BEGIN { path = "" } /^worktree / { path = substr($0, 10) } /^branch / { if ($2 == branch) print path }')

    if [ -n "$WORKTREE" ]; then
      TARGET="$WORKTREE"
      echo "Rebasing branch '$branch' in worktree: $TARGET"
    else
      TARGET="."
      git checkout "$branch"
    fi

    git -C "$TARGET" rebase "$BASE"
    if [ $? -ne 0 ]; then
      echo "Rebase failed in branch '$branch'"
      git -C "$TARGET" rebase --abort
    fi
  done
  git checkout $BASE
}

